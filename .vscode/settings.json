{
  "latex-workshop.latex.outDir": "build",

  "latex-workshop.latex.tools": [
    {
      "name": "latexmk_build",
      "command": "latexmk",
      "args": [
        "-pdf",
        "-bibtex",
        "-halt-on-error",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-synctex=1",
        "-outdir=build",
        "%DOC%"
      ],
      "env": {
        "BIBINPUTS": ".;..;",
        "BSTINPUTS": ".;..;"
      }
    },
    {
      "name": "copy_pdf",
      "command": "cmd",
      "args": [
        "/c",
        "copy /Y build\\main.pdf ..\\Thesis.pdf >nul 2>&1"
      ]
    }
  ],

  "latex-workshop.latex.recipes": [
    {
      "name": "latexmk + copy",
      "tools": ["latexmk_build", "copy_pdf"]
    }
  ],

  "latex-workshop.latex.recipe.default": "latexmk + copy",
  "latex-workshop.latex.autoBuild.run": "onSave",
  "latex-workshop.latex.build.forceRecipeUsage": true
}